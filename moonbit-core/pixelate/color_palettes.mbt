///|
pub fn find_closest_brand_color(
  rgb : RgbColor,
  brand_palette : Array[BrandColor],
) -> BrandColor {
  let lab = rgb_to_lab(rgb)
  let mut min_dist = 1000000000.0
  let mut best_color = brand_palette[0]

  for i = 0; i < brand_palette.length(); i = i + 1 {
    let bc = brand_palette[i]
    let bc_lab = { l: bc.l, a: bc.a, b: bc.b_val }
    let dist = delta_e_00(lab, bc_lab)
    if dist < min_dist {
      min_dist = dist
      best_color = bc
    }
  }
  best_color
}
