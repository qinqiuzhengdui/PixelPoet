// Bead Brand Color Palettes Database
// This module provides predefined color palettes for popular bead brands:
// - Perler (Standard MIDI 5mm)
// - Hama (MIDI 5mm)
// - Artkal (S-5mm Soft Beads)

///|
pub struct BrandColor {
  pub name : String
  pub code : String
  pub r : Int
  pub g : Int
  pub b : Int
  pub l : Double
  pub a : Double
  pub b_val : Double
}

